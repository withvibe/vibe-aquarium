# =========================================================================
# Vibe Aquarium — environment template
# Copy this file to .env  ( cp .env.example .env )  and edit values.
# Docker Compose auto-loads .env from the project root.
# =========================================================================

# --- Local / standalone mode (docker compose up) ---------------------------

# Host port to expose the aquarium on. Useful when running multiple
# client sandboxes on one host (each with its own .env / project dir).
PORT=3000

# Container name. In standalone mode this is just cosmetic; in Traefik
# mode it must be unique per client (it's used as the router ID).
CLIENT_ID=vibe-aquarium


# --- Traefik mode (docker compose -f docker-compose.yml -f docker-compose.traefik.yml up) ---

# Public hostname Traefik should route to this container.
# Example: client42.aquarium.withvibe.dev
HOSTNAME=

# Name of the external Docker network Traefik is attached to.
# Create once on the host:  docker network create traefik
TRAEFIK_NETWORK=traefik

# Traefik entrypoint and cert resolver names — must match your
# Traefik static config.
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
